{
  "group/quicklinks": {
    "orientation": "horizontal",
    "modules": [
      "custom/filemanager",
      "custom/browser",
      "custom/terminal"
    ]
  },
  "group/devices": {
    "orientation": "horizontal",
    "modules": [
      "pulseaudio",
      "bluetooth",
      "network"
    ]
  },
  "group/system": {
    "orientation": "horizontal",
    "modules": [
      "hyprland/language",
      "custom/updates",
      "custom/swaync",
      "custom/copyq"
    ]
  },

  "include": ["~/.config/waybar/dcol_modules/clock.json"],

  "hyprland/language": {
    "format": "󰌌   {}",
    "format-en": "EN",
    "format-uk": "UA",
    "format-de": "DE",
    "on-click": "hyprctl switchxkblayout all next",
    "tooltip": false
  },

  "custom/copyq": {
    "format": "󰅍",
    "on-click": "copyq toggle",
    "tooltip": false
  },

  "bluetooth": {
    "format": "󰂯",
    "format-disabled": "",
    "format-connected": " {num_connections}",
    "on-click": "blueman-manager",
    "on-click-right": "blueman-manager",
    "tooltip-format": " {device_alias}",
    "tooltip-format-connected": "{device_enumerate}",
    "tooltip-format-enumerate-connected": " {device_alias}"
  },

  "custom/filemanager": {
    "format": "",
    "on-click": "nautilus",
    "tooltip": false
  },
  "custom/terminal": {
    "format": "",
    "on-click": "kitty",
    "tooltip": false
  },
  "custom/browser": {
    "format": "",
    "on-click": "firefox",
    "tooltip": false
  },
  "custom/appmenu": {
    "format": "APPS",
    "on-click": "rofi -show drun -theme ~/.config/rofi/launchpad.rasi",
    "on-click-right": "rofi -show drun -theme ~/.config/rofi/spotlight.rasi",
    "tooltip": false
  },

  "network": {
    "format-wifi": "󰤨   {signalStrength}%",
    "format-ethernet": "󱘖",
    "tooltip-format": "󱘖  {ipaddr}  {bandwidthUpBytes}  {bandwidthDownBytes}",
    "format-linked": "󱘖  {ifname} (No IP)",
    "format-disconnected": " Disconnected",
    "format-alt": "󰤨  {essid}",
    "on-click": "networkmanager_dmenu",
    "interval": 5
  },

  "pulseaudio": {
    "format": "{icon}    {volume}%",
    "format-muted": "",
    "on-click": "~/.config/hypr/scripts/waybar-vol-progbar.sh --toggle",
    "on-click-right": "pavucontrol-qt",
    "on-scroll-up": "~/.config/hypr/scripts/waybar-vol-progbar.sh --inc",
    "on-scroll-down": "~/.config/hypr/scripts/waybar-vol-progbar.sh --dec",
    "tooltip-format": "{icon} {desc}",
    "format-icons": {
      "headphone": ["", "", ""],
      "hands-free": "",
      "headset": "",
      "phone": "",
      "portable": "",
      "car": "",
      "default": ["", "", ""]
    }
  },

  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": {},
    "icon-theme": "${i_theme}",
    "spacing": 0,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "on-click-right": "fullscreen",
    "ignore-list": [
      "com.github.hluk.copyq",
      "alacritty-dropterm",
      "feathernotes",
      "ranger",
      "org.keepassxc.KeePassXC"
    ],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    }
  },

  "custom/swaync": {
    "tooltip": false,
    "format": "{icon} {text}",
    "format-icons": {
      "notification": "󰂚",
      "none": "󰂜",
      "dnd-notification": "󰂛",
      "dnd-none": "󰂛",
      "inhibited-notification": "󰂚",
      "inhibited-none": "󰂜",
      "dnd-inhibited-notification": "󰂛",
      "dnd-inhibited-none": "󰂛"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

  "custom/updates": {
    "format": "  {}",
    "exec": "~/.config/hypr/scripts/updates.sh",
    "restart-interval": 60,
    "return-type": "json",
    "escape": true,
    "on-click": "~/.config/hypr/scripts/updates.sh up",
    "tooltip-format": "{}",
    "tooltip": true
  },

  "hyprland/workspaces": {
    "on-scroll-up": "hyprctl dispatch workspace -1",
    "on-scroll-down": "hyprctl dispatch workspace +1",
    "all-outputs": true,
    "active-only": false,
    "on-click": "activate",
    "persistent-workspaces": {
      "*": 5
    }
  },

  "group/l-apps":       { "orientation": "horizontal", "modules": [] },
  "group/r-apps":       { "orientation": "horizontal", "modules": [] },
  "group/l-quicklinks": { "orientation": "horizontal", "modules": [] },
  "group/r-quicklinks": { "orientation": "horizontal", "modules": [] },
  "group/l-workspaces": { "orientation": "horizontal", "modules": [] },
  "group/r-workspaces": { "orientation": "horizontal", "modules": [] },
  "group/l-taskbar":    { "orientation": "horizontal", "modules": [] },
  "group/r-taskbar":    { "orientation": "horizontal", "modules": [] },
  "group/l-misc":       { "orientation": "horizontal", "modules": [] },
  "group/r-misc":       { "orientation": "horizontal", "modules": [] },
  "group/l-timer":      { "orientation": "horizontal", "modules": [] },
  "group/r-timer":      { "orientation": "horizontal", "modules": [] },
  "group/l-devices":    { "orientation": "horizontal", "modules": [] },
  "group/r-devices":    { "orientation": "horizontal", "modules": [] },
  "group/l-system":     { "orientation": "horizontal", "modules": [] },
  "group/r-system":     { "orientation": "horizontal", "modules": [] }
}