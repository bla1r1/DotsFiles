{
  "group/quicklinks": {
    "orientation": "horizontal",
    "modules": [
      "custom/filemanager",
      "custom/browser",
      "custom/terminal"
    ]
  },
  "group/devices": {
    "orientation": "horizontal",
    "modules": [
      "pulseaudio",
      "custom/mic",
      "backlight",
      "custom/kbd-backlight",
      "bluetooth",
      "network",
      "battery"
    ]
  },
  "group/system": {
    "orientation": "horizontal",
    "modules": [
      "sway/language",
      "custom/updates",
      "custom/swaync",
      "custom/copyq"
    ]
  },
  "group/stats": {
    "orientation": "horizontal",
    "modules": [
      "cpu",
      "memory",
      "temperature"
    ]
  },
  "include": [
    "~/.config/waybar/dcol_modules/clock.json"
  ],
  "custom/copyq": {
    "format": "¾░àı",
    "on-click": "copyq toggle",
    "tooltip": false
  },
  "bluetooth": {
    "format": "¾░é»",
    "format-disabled": "¾░é▓",
    "format-connected": "´èô {num_connections}",
    "on-click": "blueman-manager",
    "on-click-right": "blueman-manager",
    "tooltip-format": "´èô {device_alias}",
    "tooltip-format-connected": "{device_enumerate}",
    "tooltip-format-enumerate-connected": "´èô {device_alias}"
  },
  "custom/filemanager": {
    "format": "´ü╝",
    "on-click": "nautilus",
    "tooltip": false
  },
  "custom/terminal": {
    "format": "´Æë",
    "on-click": "kitty",
    "tooltip": false
  },
  "custom/browser": {
    "format": "´ë®",
    "on-click": "firefox",
    "tooltip": false
  },
  "custom/appmenu": {
    "format": "APPS",
    "on-click": "rofi -show drun -theme ~/.config/rofi/launchpad.rasi",
    "on-click-right": "rofi -show drun -theme ~/.config/rofi/spotlight.rasi",
    "tooltip": false
  },
  "network": {
    "format-wifi": "¾░ñ¿   {signalStrength}%",
    "format-ethernet": "¾▒İû",
    "tooltip-format": "¾▒İû  {ipaddr} ´ä╣ {bandwidthUpBytes} ´ä║ {bandwidthDownBytes}",
    "format-linked": "¾▒İû  {ifname} (No IP)",
    "format-disconnected": "´ü▒ Disconnected",
    "format-alt": "¾░ñ¿  {essid}",
    "on-click": "networkmanager_dmenu",
    "interval": 5
  },
  "pulseaudio": {
    "format": "{icon}    {volume}%",
    "format-muted": "´æĞ",
    "on-click": "bash ~/.config/sway/scripts/audio-control.sh --toggle",
    "on-click-right": "pavucontrol-qt",
    "on-scroll-up": "bash ~/.config/sway/scripts/audio-control.sh --inc 5",
    "on-scroll-down": "bash ~/.config/sway/scripts/audio-control.sh --dec 5",
    "tooltip-format": "{icon} {desc}",
    "format-icons": {
      "headphone": ["´ÇĞ", "´Çğ", "´Ç¿"],
      "hands-free": "´ÇÑ",
      "headset": "´ÇÑ",
      "phone": "´éò",
      "portable": "´éò",
      "car": "´å╣",
      "default": ["´ÇĞ", "´Çğ", "´Ç¿"]
    }
  },
  "custom/mic": {
    "exec": "bash ~/.config/sway/scripts/mic-control.sh --get-muted | sed 's/true/¾░ı¡/;s/false/¾░ı¼/'",
    "interval": 2,
    "format": "  {}  ",
    "on-click": "bash ~/.config/sway/scripts/mic-control.sh --toggle",
    "tooltip-format": "Left click: toggle mic",
    "tooltip": true
  },
  "battery": {
    "states": {
      "good": 80,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-charging": "¾░éä  {capacity}%",
    "format-plugged": "¾░ÜÑ  {capacity}%",
    "format-full": "¾░ü╣  Full",
    "format-icons": ["¾░ü║", "¾░ü╗", "¾░ü╝", "¾░ü¢", "¾░ü¥", "¾░ü┐", "¾░éÇ", "¾░éü", "¾░éé", "¾░ü╣"],
    "on-click-right": "gnome-power-statistics",
    "tooltip-format": "{timeTo} ÔÇö {power}W",
    "interval": 30
  },
  "backlight": {
    "format": "{icon}  {percent}%",
    "format-icons": ["¾░âŞ", "¾░âş", "¾░âá"],
    "on-scroll-up": "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-",
    "tooltip": false
  },
  "custom/kbd-backlight": {
    "exec": "bash ~/.config/sway/scripts/kbd-backlight.sh --get",
    "interval": 2,
    "format": "¾░îî  {}%",
    "on-scroll-up": "bash ~/.config/sway/scripts/kbd-backlight.sh --inc",
    "on-scroll-down": "bash ~/.config/sway/scripts/kbd-backlight.sh --dec",
    "on-click": "bash ~/.config/sway/scripts/kbd-backlight.sh --off",
    "tooltip-format": "Scroll: adjust\nClick: turn off",
    "tooltip": true
  },
  "cpu": {
    "format": "´ïø    {usage}%",
    "interval": 2,
    "on-click": "kitty --title btop -e btop",
    "tooltip": false
  },
  "memory": {
    "format": "¾░ıø    {used:0.1f}G",
    "interval": 5,
    "on-click": "kitty --title btop -e btop",
    "tooltip-format": "{used:0.1f}G / {total:0.1f}G used\n{avail:0.1f}G available"
  },
  "temperature": {
    "critical-threshold": 80,
    "format": "{icon}  {temperatureC}┬░C",
    "format-icons": ["´ïï", "´ïè", "´ïë", "´ïê", "´ïç"],
    "interval": 5,
    "tooltip": false
  },
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": {},
    "icon-theme": "${i_theme}",
    "spacing": 0,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "on-click-right": "fullscreen",
    "ignore-list": [
      "com.github.hluk.copyq",
      "alacritty-dropterm",
      "feathernotes",
      "ranger",
      "org.keepassxc.KeePassXC"
    ],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    }
  },
  "custom/swaync": {
    "tooltip": false,
    "format": "{icon} {text}",
    "format-icons": {
      "notification": "¾░éÜ",
      "none": "¾░é£",
      "dnd-notification": "¾░éø",
      "dnd-none": "¾░éø",
      "inhibited-notification": "¾░éÜ",
      "inhibited-none": "¾░é£",
      "dnd-inhibited-notification": "¾░éø",
      "dnd-inhibited-none": "¾░éø"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "custom/updates": {
    "format": "´é½  {}",
    "exec": "~/.config/sway/scripts/updates.sh",
    "restart-interval": 60,
    "return-type": "json",
    "escape": true,
    "on-click": "~/.config/sway/scripts/updates.sh up",
    "tooltip-format": "{}",
    "tooltip": true
  },
  "sway/language": {
    "format": "¾░îî   {}",
    "format-en": "EN",
    "format-uk": "UA",
    "format-de": "DE",
    "on-click": "swaymsg input type:keyboard xkb_switch_layout next",
    "tooltip": false
  },
  "sway/workspaces": {
    "on-scroll-up": "swaymsg workspace prev",
    "on-scroll-down": "swaymsg workspace next",
    "all-outputs": true,
    "on-click": "activate",
    "persistent-workspaces": {
      "*": 5
    }
  }
}