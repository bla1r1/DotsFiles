{
  "group/quicklinks": {
    "orientation": "horizontal",
    "modules": [
      "custom/filemanager",
      "custom/browser",
      "custom/terminal"
    ]
  },
  "group/devices": {
    "orientation": "horizontal",
    "modules": [
      "pulseaudio",
      "backlight",
      "bluetooth",
      "network",
      "battery"
    ]
  },
  "group/system": {
    "orientation": "horizontal",
    "modules": [
      "sway/language",
      "custom/updates",
      "custom/swaync",
      "custom/copyq"
    ]
  },
  "group/stats": {
    "orientation": "horizontal",
    "modules": [
      "cpu",
      "memory",
      "temperature"
    ]
  },
  "include": [
    "~/.config/waybar/dcol_modules/clock.json"
  ],
  "custom/copyq": {
    "format": "󰅍",
    "on-click": "copyq toggle",
    "tooltip": false
  },
  "bluetooth": {
    "format": "󰂯",
    "format-disabled": "",
    "format-connected": " {num_connections}",
    "on-click": "blueman-manager",
    "on-click-right": "blueman-manager",
    "tooltip-format": " {device_alias}",
    "tooltip-format-connected": "{device_enumerate}",
    "tooltip-format-enumerate-connected": " {device_alias}"
  },
  "custom/filemanager": {
    "format": "",
    "on-click": "nautilus",
    "tooltip": false
  },
  "custom/terminal": {
    "format": "",
    "on-click": "kitty",
    "tooltip": false
  },
  "custom/browser": {
    "format": "",
    "on-click": "firefox",
    "tooltip": false
  },
  "custom/appmenu": {
    "format": "APPS",
    "on-click": "rofi -show drun -theme ~/.config/rofi/launchpad.rasi",
    "on-click-right": "rofi -show drun -theme ~/.config/rofi/spotlight.rasi",
    "tooltip": false
  },
  "network": {
    "format-wifi": "󰤨   {signalStrength}%",
    "format-ethernet": "󱘖",
    "tooltip-format": "󱘖  {ipaddr}  {bandwidthUpBytes}  {bandwidthDownBytes}",
    "format-linked": "󱘖  {ifname} (No IP)",
    "format-disconnected": " Disconnected",
    "format-alt": "󰤨  {essid}",
    "on-click": "networkmanager_dmenu",
    "interval": 5
  },
  "pulseaudio": {
    "format": "{icon}    {volume}%",
    "format-muted": "",
    "on-click": "~/.config/sway/scripts/waybar-vol-progbar.sh --toggle",
    "on-click-right": "pavucontrol-qt",
    "on-scroll-up": "~/.config/sway/scripts/waybar-vol-progbar.sh --inc",
    "on-scroll-down": "~/.config/sway/scripts/waybar-vol-progbar.sh --dec",
    "tooltip-format": "{icon} {desc}",
    "format-icons": {
      "headphone": [
        "",
        "",
        ""
      ],
      "hands-free": "",
      "headset": "",
      "phone": "",
      "portable": "",
      "car": "",
      "default": [
        "",
        "",
        ""
      ]
    }
  },
  "battery": {
    "states": {
      "good": 80,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-charging": "󰂄  {capacity}%",
    "format-plugged": "󰚥  {capacity}%",
    "format-full": "󰁹  Full",
    "format-icons": [
      "󰁺",
      "󰁻",
      "󰁼",
      "󰁽",
      "󰁾",
      "󰁿",
      "󰂀",
      "󰂁",
      "󰂂",
      "󰁹"
    ],
    "on-click-right": "gnome-power-statistics",
    "tooltip-format": "{timeTo} — {power}W",
    "interval": 30
  },
  "backlight": {
    "format": "{icon}  {percent}%",
    "format-icons": [
      "󰃞",
      "󰃟",
      "󰃠"
    ],
    "on-scroll-up": "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-",
    "tooltip": false
  },
  "cpu": {
    "format": "    {usage}%",
    "interval": 2,
    "on-click": "kitty --title btop -e btop",
    "tooltip": false
  },
  "memory": {
    "format": "󰍛    {used:0.1f}G",
    "interval": 5,
    "on-click": "kitty --title btop -e btop",
    "tooltip-format": "{used:0.1f}G / {total:0.1f}G used\n{avail:0.1f}G available"
  },
  "temperature": {
  "critical-threshold": 80,
  "format": "{icon}  {temperatureC}°C",
  "format-icons": ["","","","",""],
  "interval": 5,
  "tooltip": false
},
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": {},
    "icon-theme": "${i_theme}",
    "spacing": 0,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "on-click-right": "fullscreen",
    "ignore-list": [
      "com.github.hluk.copyq",
      "alacritty-dropterm",
      "feathernotes",
      "ranger",
      "org.keepassxc.KeePassXC"
    ],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    }
  },
  "custom/swaync": {
    "tooltip": false,
    "format": "{icon} {text}",
    "format-icons": {
      "notification": "󰂚",
      "none": "󰂜",
      "dnd-notification": "󰂛",
      "dnd-none": "󰂛",
      "inhibited-notification": "󰂚",
      "inhibited-none": "󰂜",
      "dnd-inhibited-notification": "󰂛",
      "dnd-inhibited-none": "󰂛"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "custom/updates": {
    "format": "  {}",
    "exec": "~/.config/sway/scripts/updates.sh",
    "restart-interval": 60,
    "return-type": "json",
    "escape": true,
    "on-click": "~/.config/sway/scripts/updates.sh up",
    "tooltip-format": "{}",
    "tooltip": true
  },
  "group/l-apps": {
    "orientation": "horizontal",
    "modules": []
  },
  "group/r-apps": {
    "orientation": "horizontal",
    "modules": []
  },
  "group/l-quicklinks": {
    "orientation": "horizontal",
    "modules": []
  },
  "group/r-quicklinks": {
    "orientation": "horizontal",
    "modules": []
  },
  "group/l-workspaces": {
    "orientation": "horizontal",
    "modules": []
  },
  "group/r-workspaces": {
    "orientation": "horizontal",
    "modules": []
  },
  "group/l-taskbar": {
    "orientation": "horizontal",
    "modules": []
  },
  "group/r-taskbar": {
    "orientation": "horizontal",
    "modules": []
  },
  "group/l-misc": {
    "orientation": "horizontal",
    "modules": []
  },
  "group/r-misc": {
    "orientation": "horizontal",
    "modules": []
  },
  "group/l-timer": {
    "orientation": "horizontal",
    "modules": []
  },
  "group/r-timer": {
    "orientation": "horizontal",
    "modules": []
  },
  "group/l-devices": {
    "orientation": "horizontal",
    "modules": []
  },
  "group/r-devices": {
    "orientation": "horizontal",
    "modules": []
  },
  "group/l-system": {
    "orientation": "horizontal",
    "modules": []
  },
  "group/r-system": {
    "orientation": "horizontal",
    "modules": []
  },
  "sway/language": {
    "format": "󰌌   {}",
    "format-en": "EN",
    "format-uk": "UA",
    "format-de": "DE",
    "on-click": "swaymsg input type:keyboard xkb_switch_layout next",
    "tooltip": false
  },
  "sway/workspaces": {
    "on-scroll-up": "swaymsg workspace prev",
    "on-scroll-down": "swaymsg workspace next",
    "all-outputs": true,
    "on-click": "activate",
    "persistent-workspaces": {
      "*": 5
    }
  }
}
