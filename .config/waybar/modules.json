{
  "group/quicklinks": {
    "orientation": "horizontal",
    "modules": [
      "custom/filemanager",
      "custom/browser",
      "custom/terminal"
    ]
  },
  "group/devices": {
    "orientation": "horizontal",
    "modules": [
      "pulseaudio",
      "backlight",
      "bluetooth",
      "network",
      "battery"
    ]
  },
  "group/system": {
    "orientation": "horizontal",
    "modules": [
      "hyprland/language",
      "custom/updates",
      "custom/swaync",
      "custom/copyq"
    ]
  },
  "group/stats": {
    "orientation": "horizontal",
    "modules": [
      "cpu",
      "memory",
      "temperature"
    ]
  },

  "include": ["~/.config/waybar/dcol_modules/clock.json"],

  "hyprland/language": {
    "format": "¾░îî   {}",
    "format-en": "EN",
    "format-uk": "UA",
    "format-de": "DE",
    "on-click": "hyprctl switchxkblayout all next",
    "tooltip": false
  },

  "custom/copyq": {
    "format": "¾░àì",
    "on-click": "copyq toggle",
    "tooltip": false
  },

  "bluetooth": {
    "format": "¾░é»",
    "format-disabled": "",
    "format-connected": "´èô {num_connections}",
    "on-click": "blueman-manager",
    "on-click-right": "blueman-manager",
    "tooltip-format": "´èô {device_alias}",
    "tooltip-format-connected": "{device_enumerate}",
    "tooltip-format-enumerate-connected": "´èô {device_alias}"
  },

  "custom/filemanager": {
    "format": "´ü╝",
    "on-click": "nautilus",
    "tooltip": false
  },
  "custom/terminal": {
    "format": "´Æë",
    "on-click": "kitty",
    "tooltip": false
  },
  "custom/browser": {
    "format": "´ë®",
    "on-click": "firefox",
    "tooltip": false
  },
  "custom/appmenu": {
    "format": "APPS",
    "on-click": "rofi -show drun -theme ~/.config/rofi/launchpad.rasi",
    "on-click-right": "rofi -show drun -theme ~/.config/rofi/spotlight.rasi",
    "tooltip": false
  },

  "network": {
    "format-wifi": "¾░ñ¿   {signalStrength}%",
    "format-ethernet": "¾▒ÿû",
    "tooltip-format": "¾▒ÿû  {ipaddr} ´ä╣ {bandwidthUpBytes} ´ä║ {bandwidthDownBytes}",
    "format-linked": "¾▒ÿû  {ifname} (No IP)",
    "format-disconnected": "´ü▒ Disconnected",
    "format-alt": "¾░ñ¿  {essid}",
    "on-click": "networkmanager_dmenu",
    "interval": 5
  },

  "pulseaudio": {
    "format": "{icon}    {volume}%",
    "format-muted": "´æª",
    "on-click": "~/.config/hypr/scripts/waybar-vol-progbar.sh --toggle",
    "on-click-right": "pavucontrol-qt",
    "on-scroll-up": "~/.config/hypr/scripts/waybar-vol-progbar.sh --inc",
    "on-scroll-down": "~/.config/hypr/scripts/waybar-vol-progbar.sh --dec",
    "tooltip-format": "{icon} {desc}",
    "format-icons": {
      "headphone": ["´Çª", "´Çº", "´Ç¿"],
      "hands-free": "´ÇÑ",
      "headset": "´ÇÑ",
      "phone": "´éò",
      "portable": "´éò",
      "car": "´å╣",
      "default": ["´Çª", "´Çº", "´Ç¿"]
    }
  },

  "battery": {
    "states": {
      "good": 80,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-charging": "¾░éä  {capacity}%",
    "format-plugged": "¾░ÜÑ  {capacity}%",
    "format-full": "¾░ü╣  Full",
    "format-icons": ["¾░ü║", "¾░ü╗", "¾░ü╝", "¾░ü¢", "¾░ü¥", "¾░ü┐", "¾░éÇ", "¾░éü", "¾░éé", "¾░ü╣"],
    "on-click-right": "gnome-power-statistics",
    "tooltip-format": "{timeTo} ÔÇö {power}W",
    "interval": 30
  },

  "backlight": {
    "format": "{icon}  {percent}%",
    "format-icons": ["¾░â×", "¾░âƒ", "¾░âá"],
    "on-scroll-up": "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-",
    "tooltip": false
  },

  "cpu": {
    "format": "´ïø    {usage}%",
    "interval": 2,
    "on-click": "kitty --title btop -e btop",
    "tooltip": false
  },

  "memory": {
    "format": "¾░ìø    {used:0.1f}G",
    "interval": 5,
    "on-click": "kitty --title btop -e btop",
    "tooltip-format": "{used:0.1f}G / {total:0.1f}G used\n{avail:0.1f}G available"
  },

  "temperature": {
    "critical-threshold": 80,
    "format": "­ƒîí´©Å   {temperatureC}┬░C",
    "format-critical": "­ƒöÑ   {temperatureC}┬░C",
    "interval": 5,
    "tooltip": false
  },

  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": {},
    "icon-theme": "${i_theme}",
    "spacing": 0,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "on-click-right": "fullscreen",
    "ignore-list": [
      "com.github.hluk.copyq",
      "alacritty-dropterm",
      "feathernotes",
      "ranger",
      "org.keepassxc.KeePassXC"
    ],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    }
  },

  "custom/swaync": {
    "tooltip": false,
    "format": "{icon} {text}",
    "format-icons": {
      "notification": "¾░éÜ",
      "none": "¾░é£",
      "dnd-notification": "¾░éø",
      "dnd-none": "¾░éø",
      "inhibited-notification": "¾░éÜ",
      "inhibited-none": "¾░é£",
      "dnd-inhibited-notification": "¾░éø",
      "dnd-inhibited-none": "¾░éø"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

  "custom/updates": {
    "format": "´é½  {}",
    "exec": "~/.config/hypr/scripts/updates.sh",
    "restart-interval": 60,
    "return-type": "json",
    "escape": true,
    "on-click": "~/.config/hypr/scripts/updates.sh up",
    "tooltip-format": "{}",
    "tooltip": true
  },

  "hyprland/workspaces": {
    "on-scroll-up": "hyprctl dispatch workspace -1",
    "on-scroll-down": "hyprctl dispatch workspace +1",
    "all-outputs": true,
    "active-only": false,
    "on-click": "activate",
    "persistent-workspaces": {
      "*": 5
    }
  },

  "group/l-apps":       { "orientation": "horizontal", "modules": [] },
  "group/r-apps":       { "orientation": "horizontal", "modules": [] },
  "group/l-quicklinks": { "orientation": "horizontal", "modules": [] },
  "group/r-quicklinks": { "orientation": "horizontal", "modules": [] },
  "group/l-workspaces": { "orientation": "horizontal", "modules": [] },
  "group/r-workspaces": { "orientation": "horizontal", "modules": [] },
  "group/l-taskbar":    { "orientation": "horizontal", "modules": [] },
  "group/r-taskbar":    { "orientation": "horizontal", "modules": [] },
  "group/l-misc":       { "orientation": "horizontal", "modules": [] },
  "group/r-misc":       { "orientation": "horizontal", "modules": [] },
  "group/l-timer":      { "orientation": "horizontal", "modules": [] },
  "group/r-timer":      { "orientation": "horizontal", "modules": [] },
  "group/l-devices":    { "orientation": "horizontal", "modules": [] },
  "group/r-devices":    { "orientation": "horizontal", "modules": [] },
  "group/l-system":     { "orientation": "horizontal", "modules": [] },
  "group/r-system":     { "orientation": "horizontal", "modules": [] }
}
