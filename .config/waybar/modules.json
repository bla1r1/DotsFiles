{

    // Group Quicklinks
    "group/quicklinks": {
        "orientation": "horizontal",
        "modules": [
            "custom/filemanager",
            "custom/browser",
            "custom/terminal"
//          "custom/editor",
//            "custom/obsidian"

         ]
    },

    // Group Time
    "group/time": {
        "orientation": "horizontal",
        "modules": [
        "custom/timer"
         ]
    },

        // Group Devices
    "group/devices": {
        "orientation": "horizontal",
        "modules": [
            "pulseaudio",
            "bluetooth",
            "network"
         ]
    },

        // Group System
    "group/system": {
        "orientation": "horizontal",
        "modules": [
            "hyprland/language",
            "custom/updates",
            "custom/swaync",
            "custom/copyq"
         ]
    },

    "hyprland/language": {
        "format": "¾░îî   {}",
        "format-en": "EN",
        "format-uk": "UA",
        "format-de": "DE",
        "on-click": "hyprctl switchxkblayout all next",
        "tooltip": false
    },

    "bluetooth": {
        "format": "",
        "format-disabled": "", // an empty format will hide the module
        "format-connected": "´èô {num_connections}",
        "on-click": "blueman-manager",
        "on-click-right": "blueman-manager",
        "tooltip-format": "´èô {device_alias}",
        "tooltip-format-connected": "{device_enumerate}",
        "tooltip-format-enumerate-connected": "´èô {device_alias}"
    },

    "custom/cliphist": {
        "format": "¾░àì{}",
        "exec": "echo ; echo clipboard",
        "on-click": "sleep 0.1 && ~/.config/hypr/scripts/cliphist.sh c",
        "on-click-right": "sleep 0.1 && ~/.config/hypr/scripts/cliphist.sh d",
        "on-click-middle": "sleep 0.1 && ~/.config/hypr/scripts/cliphist.sh w",
        "interval" : 86400, // once every day
        "tooltip": true,
        "on-scroll-up": "swaync-client -C",
        "on-scroll-down": "swaync-client -t -sw"
    },

        "custom/copyq": {
        "format": "¾░àì",
        "on-click": "copyq toggle",
        "tooltip": false
    },

    "include": ["~/.config/waybar/dcol_modules/clock.json"],

    "custom/timer": {
        "align": 0,
        "tooltip": false,
        "exec": "$HOME/.config/hypr/scripts/waybar-timer.sh",
        "on-click": "date --date='30 minutes' +%s > /var/tmp/waybar_timer",
        "on-click-right": "echo READY > /var/tmp/waybar_timer",
        "on-click-middle": "date --date='45 minute' +%s > /var/tmp/waybar_timer",
        "on-scroll-up": "$HOME/.config/hypr/scripts/waybar-timer-steps.sh up",
        "on-scroll-down": "$HOME/.config/hypr/scripts/waybar-timer-steps.sh down",
        "interval": 1
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "´êà",
            "deactivated": "´êä"
        }
    },

    "cpu": {
        "interval": 10,
        "format": "¾░ìø {usage}%",
        "format-alt": "{icon0}{icon1}{icon2}{icon3}",
        "format-icons": ["Ôûü", "Ôûé", "Ôûâ", "Ôûä", "Ôûà", "Ôûå", "Ôûç", "Ôûê"]
    },

    "custom/padd": {
        "format": "",
        "interval" : "once",
        "tooltip": false
    },

    "custom/gpuinfo": {
        "exec": " ~/.config/hypr/scripts/gpuinfo.sh",
        "return-type": "json",
        "format": "´ïï {}",
        "interval": 5, // once every 5 seconds
        "tooltip": true,
        "max-length": 1000
    },

    "custom/filemanager": {
        "format": "´ü╝ ",
        "on-click": "nautilus",
        "tooltip": false
    },

     "custom/terminal": {
        "format": "´Æë ",
        "on-click": "kitty",
        "tooltip": false
    },

    "custom/editor": {
        "format": "´ïÉ",
        "on-click": "geany",
        "tooltip": false
    },

    "custom/browser": {
        "format": "´ë® ",
        "on-click": "firefox",
        "tooltip": false
    },
    "custom/appmenu": {
        "format": "APPS",
        "on-click": "rofi -show drun -theme ~/.config/rofi/launchpad.rasi",
        "on-click-right": "rofi -show drun -theme ~/.config/rofi/spotlight.rasi",
        "tooltip": false
    },

    "memory": {
        "interval": 30,
        "format": "{used:0.3f} GB",
        "format-alt": "¾░¥å {percentage}%",
        "max-length": 10,
        "tooltip": true,
        "tooltip-format": "¯ëª  {used:0.1f}GB / {total:0.1f}GB"
    },

    "mpris": {
        "format": "{player_icon} {dynamic}",
        "format-paused": "{status_icon} <i>{dynamic}</i>",
        "player-icons": {
            "default": "ÔûÂ",
            "mpv": "­ƒÄÁ"
        },
        "status-icons": {
            "paused": "ÔÅ©"
        },
        "max-length": 1000,
        "interval": 1
    },

    "network": {
        "format-wifi": "¾░ñ¿ {signalStrength}%",
        "format-ethernet": "¾▒ÿû",
        "tooltip-format": "¾▒ÿû  {ipaddr} ´ä╣ {bandwidthUpBytes} ´ä║ {bandwidthDownBytes}",
        "format-linked": "¾▒ÿû  {ifname} (No IP)",
        "format-disconnected": "´ü▒  Disconnected",
        "format-alt": "¾░ñ¿  {essid}",
        "on-click": "networkmanager_dmenu",
        "interval": 5
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "´æª",
        "on-click": "~/.config/hypr/scripts/waybar-vol-progbar.sh --toggle",
        "on-click-right": "pavucontrol-qt",
        "on-scroll-up": "~/.config/hypr/scripts/waybar-vol-progbar.sh --inc",
        "on-scroll-down": "~/.config/hypr/scripts/waybar-vol-progbar.sh --dec",
        "tooltip-format": "{icon} {desc}",
        "format-icons": {
            "headphone": ["´Çª", "´Çº", "´Ç¿"],
            "hands-free": "´ÇÑ",
            "headset": "´ÇÑ",
            "phone": "´éò",
            "portable": "´éò",
            "car": "´å╣",
            "default": ["´Çª", "´Çº", "´Ç¿"]
        }
    },

    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "´í½",
        "format-source-muted": "´ä▒",
        "on-click": "pavucontrol -t 4",
        "on-click-middle": "~/.config/hypr/scripts/volumecontrol.sh -i m",
        "on-scroll-up": "~/.config/hypr/scripts/volumecontrol.sh -i i",
        "on-scroll-down": "~/.config/hypr/scripts/volumecontrol.sh -i d",
        "tooltip-format": "{format_source} {source_desc} // {source_volume}%",
        "scroll-step": 5
    },

    "custom/spotify": {
        "exec": "/usr/bin/python3 $HOME/.config/waybar/modules/mediaplayer.py --player spotify",
        "format": "´å╝ {}",
        "return-type": "json",
        "on-click": "playerctl play-pause --player spotify",
        "on-click-right": "playerctl next --player spotify",
        "on-click-middle": "playerctl previous --player spotify",
        "on-scroll-up": "~/.config/hypr/scripts/spotifyvolumecontrol.sh up",
        "on-scroll-down": "~/.config/hypr/scripts/spotifyvolumecontrol.sh down",
        "max-length": 25,
        "escape": true,
        "tooltip": true
    },

	"wlr/taskbar": {
		"format": "{icon}",
		"icon-size": {},
		"icon-theme": "${i_theme}",
        "spacing": 0,
		"tooltip-format": "{title}",
		"on-click": "activate",
		"on-click-middle": "close",
		"on-click-right": "fullscreen",
		"ignore-list": [
            "com.github.hluk.copyq",
			"alacritty-dropterm",
            "feathernotes",
            "ranger",
            "org.keepassxc.KeePassXC"
		],
		"app_ids-mapping": {
			"firefoxdeveloperedition": "firefox-developer-edition"
		}
	},

    "tray": {
        "icon-size": {},
        "spacing": 5
    },

    "custom/ddcutil": {
        "format": "{percentage}% {icon}",
        "interval": 1,
        "format-icons": ["´ùø", "´ùÜ", "´ùÖ"],
        "exec": "~/.config/hypr/scripts/waybar-ddcutil.py",
        "return-type": "json"
    },

    "custom/ddc_brightness": {
        "format": "{icon} {percentage}%",
        "format-icons": ["´üé"],
        "exec": "~/.config/hypr/scripts/waybar-ddc-module.sh",
        "return-type": "json",
        "on-scroll-up": "echo '+' > /tmp/waybar-ddc-module-rx",
        "on-scroll-down": "echo '-' > /tmp/waybar-ddc-module-rx",
        "on-click": "echo 'min' > /tmp/waybar-ddc-module-rx",
        "on-click-right": "echo 'max' > /tmp/waybar-ddc-module-rx",
        "tooltip": false,
    },

    "custom/swaync": {
        "tooltip": false,
        "format": "{icon} {text}",
        "format-icons": {
            "notification": "¾░éÜ",
            "none": "¾░é£",
            "dnd-notification": "¾░éø",
            "dnd-none": "¾░éø",
            "inhibited-notification": "¾░éÜ",
            "inhibited-none": "¾░é£",
            "dnd-inhibited-notification": "¾░éø",
            "dnd-inhibited-none": "¾░éø"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },

    "custom/updates": {
        "format": "´é½  {}",
        "exec": "~/.config/hypr/scripts/updates.sh",
        "restart-interval": 60,
        "return-type": "json",
        "escape": true,
        "on-click": "~/.config/hypr/scripts/updates.sh up",
        "tooltip-format": "{}",
        "tooltip": true
    },

    "hyprland/window": {
        "format": " ´îâ {}",
        "separate-outputs": true,
        "rewrite": {
            "${USER}@${set_sysname}:(.*)": "$1 ´Æë",
            "(.*) ÔÇö Mozilla Firefox": "$1 ¾░ê╣",
            "(.*)Mozilla Firefox": "Firefox ¾░ê╣",
            "(.*) - Visual Studio Code": "$1 ¾░¿×",
            "(.*)Visual Studio Code": "Code ¾░¿×",
            "(.*) ÔÇö Dolphin": "$1 ¾░ëï",
            "(.*)Spotify": "Spotify ¾░ôç",
            "(.*)Steam": "Steam ¾░ôô"
        },
        "max-length": 1000
    },

    "hyprland/workspaces": {
        "on-scroll-up": "hyprctl dispatch workspace -1",
        "on-scroll-down": "hyprctl dispatch workspace +1",
        "all-outputs": true,
        "active-only": false,
        "on-click": "activate",
        "persistent-workspaces": {
            // START WORKSPACES
    "*": 5
            // END WORKSPACES
        }
    }
,

    // Spacer group: group/l-apps
    "group/l-apps": {
        "orientation": "horizontal",
        "modules": []
    },

    // Spacer group: group/r-apps
    "group/r-apps": {
        "orientation": "horizontal",
        "modules": []
    },

    // Spacer group: group/l-quicklinks
    "group/l-quicklinks": {
        "orientation": "horizontal",
        "modules": []
    },

    // Spacer group: group/r-quicklinks
    "group/r-quicklinks": {
        "orientation": "horizontal",
        "modules": []
    },

    // Spacer group: group/l-workspaces
    "group/l-workspaces": {
        "orientation": "horizontal",
        "modules": []
    },

    // Spacer group: group/r-workspaces
    "group/r-workspaces": {
        "orientation": "horizontal",
        "modules": []
    },

    // Spacer group: group/l-taskbar
    "group/l-taskbar": {
        "orientation": "horizontal",
        "modules": []
    },

    // Spacer group: group/r-taskbar
    "group/r-taskbar": {
        "orientation": "horizontal",
        "modules": []
    },

    // Spacer group: group/l-misc
    "group/l-misc": {
        "orientation": "horizontal",
        "modules": []
    },

    // Spacer group: group/r-misc
    "group/r-misc": {
        "orientation": "horizontal",
        "modules": []
    },

    // Spacer group: group/l-timer
    "group/l-timer": {
        "orientation": "horizontal",
        "modules": []
    },

    // Spacer group: group/r-timer
    "group/r-timer": {
        "orientation": "horizontal",
        "modules": []
    },

    // Spacer group: group/l-devices
    "group/l-devices": {
        "orientation": "horizontal",
        "modules": []
    },

    // Spacer group: group/r-devices
    "group/r-devices": {
        "orientation": "horizontal",
        "modules": []
    },

    // Spacer group: group/l-system
    "group/l-system": {
        "orientation": "horizontal",
        "modules": []
    },

    // Spacer group: group/r-system
    "group/r-system": {
        "orientation": "horizontal",
        "modules": []
